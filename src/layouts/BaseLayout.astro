---
import type { Locale } from "../i18n/config";
import { defaultLocale } from "../i18n/config";
import { getLocalizedPath } from "../i18n/path";
import SiteHeader from "../components/SiteHeader.astro";

interface Props {
  title?: string;
  description?: string;
  alternateLocaleExists?: boolean;
}

const {
  title = "evaaaaawu.com",
  description = "Personal site of Eva.",
  alternateLocaleExists = true,
} = Astro.props;

const currentLocale = (Astro.currentLocale ?? defaultLocale) as Locale;
const htmlLang = currentLocale === "zh-tw" ? "zh-Hant-TW" : "en";
const currentPath = Astro.url.pathname;
const targetLocale: Locale = currentLocale === "en" ? "zh-tw" : "en";
const alternatePath = getLocalizedPath(currentPath, targetLocale);
const site = Astro.site?.origin ?? "";
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    {
      alternateLocaleExists && (
        <>
          <link
            rel="alternate"
            hreflang={currentLocale === "zh-tw" ? "zh-Hant-TW" : "en"}
            href={`${site}${currentPath}`}
          />
          <link
            rel="alternate"
            hreflang={targetLocale === "zh-tw" ? "zh-Hant-TW" : "en"}
            href={`${site}${alternatePath}`}
          />
        </>
      )
    }
  </head>
  <body class="min-h-screen flex flex-col bg-white text-neutral-900">
    <SiteHeader alternateLocaleExists={alternateLocaleExists} />

    <main class="flex-1 p-4">
      <slot />
    </main>

    <footer class="p-4 border-t border-neutral-200 text-sm text-neutral-500">
      <slot name="footer" />
    </footer>
  </body>
</html>
